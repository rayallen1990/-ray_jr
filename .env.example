# Ray_jr Knowledge Base Platform - Environment Configuration Template
# Copy this file to .env and update with your actual values

# Application Settings
APP_NAME="Ray_jr Knowledge Base"
APP_VERSION="0.1.0"
DEBUG=false

# Database Configuration
DATABASE_URL=postgresql://ray_jr_user:changeme@localhost:5432/ray_jr

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# Qdrant Vector Store Configuration
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334

# JWT Authentication
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# API Keys
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# RAG Engine Configuration
RAG_MODEL=claude-sonnet-4.5
RAG_MAX_CONTEXT_TOKENS=100000
RAG_TOP_K=5

# Knowledge Base Repository Configuration
KNOWLEDGE_BASE_REPO=https://github.com/rayallen1990/-ray_jr-knowledge-base.git
KNOWLEDGE_BASE_PATH=./data
KNOWLEDGE_BASE_BRANCH=main
KNOWLEDGE_BASE_AUTO_SYNC=true
